APP_NAME=Casa & Terra IAM
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000
SESSION_SECRET=change-this-to-a-long-random-secret
SESSION_COOKIE_NAME=iam_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=28800

DATABASE_PATH=./data/iam.sqlite3

LDAP_SERVER=ldaps://ad.casaeterra.local:636
LDAP_BIND_DN=CN=svc-iam-readonly,OU=Service Accounts,DC=casaeterra,DC=local
LDAP_BIND_PASSWORD=change-me
LDAP_BASE_DN=DC=casaeterra,DC=local
LDAP_USER_BASE_DN=DC=casaeterra,DC=local
LDAP_GROUP_BASE_DN=DC=casaeterra,DC=local
LDAP_OPERATOR_GROUP=GG-IAM-OPERADORES
LDAP_VIEWONLY_GROUP=GG-IAM-VIEWONLY
LDAP_PAGE_SIZE=500
LDAP_USE_SSL=true

CRITICAL_GROUPS=Domain Admins,Account Operators,Backup Operators,ERP-Admin,VPN-Admin,M365-Admin,ServiceDesk-Admin,DataLake-Consulta
